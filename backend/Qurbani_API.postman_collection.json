    "item": [
        {
            "name": "Authentication",
            "item": [
                {
                    "name": "Mobile Login (Authenticate)",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Save auth token for subsequent requests",
                                    "if (pm.response.code === 200) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.environment.set(\"authToken\", jsonData.authToken);",
                                    "    pm.environment.set(\"userId\", jsonData.user.id);",
                                    "    console.log(\"Login successful! Token saved.\");",
                                    "}",
                                    "",
                                    "// Test assertions",
                                    "pm.test(\"Status code is 200\", function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test(\"Response has authToken\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('authToken');",
                                    "});",
                                    "",
                                    "pm.test(\"Response has user data\", function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('user');",
                                    "    pm.expect(jsonData.user).to.have.property('phoneNumber');",
                                    "    pm.expect(jsonData.user).to.have.property('passportNumber');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phoneNumber\": \"123456\",\n    \"passportNumber\": \"123456\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/auth/authenticate",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "authenticate"
                            ]
                        },
                        "description": "Mobile app authentication endpoint using phone number and passport number"
                    },
                    "response": []
                },
